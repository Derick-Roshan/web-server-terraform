pipeline {
    agent any

    environment {
        TF_IN_AUTOMATION = '1'
    }

    stages {
        stage('Deploy Terraform') {
            steps {
                checkout scm

                withCredentials([usernamePassword(
                    credentialsId: '016819180853',
                    usernameVariable: 'AKIAQH2UAKU23WHI7VMAD',
                    passwordVariable: 'uhRGm+PmA91vF5RUbFGlo34gcBLAkhIpohjFab6Q'
                )]) {
                    sh '''
                        terraform --version
                        terraform init
                        terraform plan
                        terraform apply -auto-approve
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Terraform success'
        }
        failure {
            echo 'Terraform failed'
        }
    }
}
