pipeline {
    agent any

    environment {
        TF_IN_AUTOMATION = '1'
    }

    stages {
        stage('Deploy Terraform') {
            steps {
                checkout scm

                withCredentials([usernamePassword(
                    credentialsId: 'terraform',
                    usernameVariable: 'AKIAQH2UAKU25VSOUEX2',
                    passwordVariable: '7Gxy1It3wvBiTXm5hB5WgjOyMGlXJB8LYepzv/TH'
                )]) {
                    sh '''
                        terraform --version
                        terraform init
                        terraform plan
                        terraform apply -auto-approve
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Terraform success'
        }
        failure {
            echo 'Terraform failed'
        }
    }
}
