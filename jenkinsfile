pipeline {
    agent any

    tools {
        terraform 'terraform'   // must match the Terraform tool name in Jenkins
    }

    environment {
        AWS_ACCESS_KEY_ID     = credentials('016819180853')
        AWS_SECRET_ACCESS_KEY = credentials('EnIyYVQDJ7ZDsR8o3bBSNtltnZ98gfS98U35XcTp')
        TF_IN_AUTOMATION      = '1'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                sh 'terraform init -input=false'
            }
        }

        stage('Terraform Plan') {
            steps {
                sh 'terraform plan -out=tfplan -input=false'
            }
        }

        stage('Terraform Apply') {
            steps {
                sh 'terraform apply -auto-approve tfplan'
            }
        }
    }

    post {
        success {
            echo '✔ Terraform applied successfully'
        }
        failure {
            echo '❌ Terraform failed'
        }
    }
}
